<!-- Performance Improvement Plan Detail Report — main datasource = List<PipDetailReportObjectiveDTO> -->
<jasperReport name="pip_detail_report" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="a2b3c4d5-e6f7-8901-abcd-ef1234567891">

    <!-- ===================== PARAMETERS (header metadata) ===================== -->
    <parameter name="reportTitle"        class="java.lang.String"/>
    <parameter name="employeeName"       class="java.lang.String"/>
    <parameter name="employeeCode"       class="java.lang.String"/>
    <parameter name="departmentName"     class="java.lang.String"/>
    <parameter name="positionName"       class="java.lang.String"/>
    <parameter name="managerName"        class="java.lang.String"/>
    <parameter name="severity"           class="java.lang.String"/>
    <parameter name="status"             class="java.lang.String"/>
    <parameter name="outcome"            class="java.lang.String"/>
    <parameter name="startDate"          class="java.lang.String"/>
    <parameter name="endDate"            class="java.lang.String"/>
    <parameter name="reason"             class="java.lang.String"/>
    <parameter name="overallComment"     class="java.lang.String"/>

    <!-- ===================== FIELDS (one row = one PipDetailReportObjectiveDTO) ===================== -->
    <field name="objectiveTitle"        class="java.lang.String"/>
    <field name="objectiveDescription"  class="java.lang.String"/>
    <field name="successCriteria"       class="java.lang.String"/>
    <field name="progressPercent"       class="java.lang.String"/>
    <field name="status"                class="java.lang.String"/>

    <!-- ===================== TITLE (printed once at top of page 1) ===================== -->
    <title height="280">
        <!-- Report heading -->
        <element kind="staticText" uuid="bb000001-0001-0001-0001-000000000001"
                 x="0" y="0" width="555" height="28"
                 fontSize="18.0" bold="true" hTextAlign="Center" vTextAlign="Middle" forecolor="#1F2937">
            <text><![CDATA[Performance Improvement Plan]]></text>
        </element>

        <!-- Info box background -->
        <element kind="rectangle" uuid="bb000003-0001-0001-0001-000000000003"
                 x="0" y="40" width="555" height="130" backcolor="#F9FAFB">
            <pen lineWidth="0.5" lineColor="#D1D5DB"/>
        </element>

        <!-- Row 1: Employee Name | Department -->
        <element kind="staticText" uuid="bb000010-0001-0001-0001-000000000010"
                 x="10" y="50" width="100" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Employee Name:]]></text>
        </element>
        <element kind="textField" uuid="bb000011-0001-0001-0001-000000000011"
                 x="112" y="50" width="175" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{employeeName} + " (" + $P{employeeCode} + ")"]]></expression>
        </element>
        <element kind="staticText" uuid="bb000012-0001-0001-0001-000000000012"
                 x="300" y="50" width="85" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Department:]]></text>
        </element>
        <element kind="textField" uuid="bb000013-0001-0001-0001-000000000013"
                 x="387" y="50" width="158" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{departmentName}]]></expression>
        </element>

        <!-- Row 2: Position | Manager -->
        <element kind="staticText" uuid="bb000014-0001-0001-0001-000000000014"
                 x="10" y="70" width="100" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Position:]]></text>
        </element>
        <element kind="textField" uuid="bb000015-0001-0001-0001-000000000015"
                 x="112" y="70" width="175" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{positionName}]]></expression>
        </element>
        <element kind="staticText" uuid="bb000016-0001-0001-0001-000000000016"
                 x="300" y="70" width="85" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Manager:]]></text>
        </element>
        <element kind="textField" uuid="bb000017-0001-0001-0001-000000000017"
                 x="387" y="70" width="158" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{managerName}]]></expression>
        </element>

        <!-- Row 3: Start Date | End Date -->
        <element kind="staticText" uuid="bb000018-0001-0001-0001-000000000018"
                 x="10" y="90" width="100" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Start Date:]]></text>
        </element>
        <element kind="textField" uuid="bb000019-0001-0001-0001-000000000019"
                 x="112" y="90" width="175" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{startDate}]]></expression>
        </element>
        <element kind="staticText" uuid="bb000020-0001-0001-0001-000000000020"
                 x="300" y="90" width="85" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[End Date:]]></text>
        </element>
        <element kind="textField" uuid="bb000021-0001-0001-0001-000000000021"
                 x="387" y="90" width="158" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{endDate}]]></expression>
        </element>

        <!-- Row 4: Status | Severity | Outcome -->
        <element kind="staticText" uuid="bb000022-0001-0001-0001-000000000022"
                 x="10" y="110" width="100" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Status:]]></text>
        </element>
        <element kind="textField" uuid="bb000023-0001-0001-0001-000000000023"
                 x="112" y="110" width="175" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{status}]]></expression>
        </element>
        <element kind="staticText" uuid="bb000024-0001-0001-0001-000000000024"
                 x="300" y="110" width="85" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Severity:]]></text>
        </element>
        <element kind="textField" uuid="bb000025-0001-0001-0001-000000000025"
                 x="387" y="110" width="158" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{severity}]]></expression>
        </element>

        <!-- Row 5: Outcome -->
        <element kind="staticText" uuid="bb000026-0001-0001-0001-000000000026"
                 x="10" y="130" width="100" height="14" fontSize="9.0" bold="true" forecolor="#374151">
            <text><![CDATA[Final Outcome:]]></text>
        </element>
        <element kind="textField" uuid="bb000027-0001-0001-0001-000000000027"
                 x="112" y="130" width="433" height="14" fontSize="9.0" forecolor="#111827">
            <expression><![CDATA[$P{outcome} != null ? $P{outcome} : "\u2014"]]></expression>
        </element>

        <!-- Reason for PIP -->
        <element kind="staticText" uuid="bb000028-0001-0001-0001-000000000028"
                 x="0" y="185" width="555" height="15" fontSize="10.0" bold="true" forecolor="#1F2937">
            <text><![CDATA[Reason / Context for PIP]]></text>
        </element>
        <element kind="textField" uuid="bb000029-0001-0001-0001-000000000029"
                 x="0" y="205" width="555" height="60" fontSize="9.0" forecolor="#4B5563"
                 textAdjust="StretchHeight">
            <expression><![CDATA[$P{reason} != null && !$P{reason}.isEmpty() ? $P{reason} : "No context details provided."]]></expression>
        </element>
    </title>

    <!-- Column header for the objectives table -->
    <columnHeader height="18">
        <element kind="rectangle" uuid="bb000030-0001-0001-0001-000000000030"
                 x="0" y="0" width="555" height="18" backcolor="#1F2937">
            <pen lineWidth="0"/>
        </element>
        <element kind="staticText" uuid="bb000031-0001-0001-0001-000000000031"
                 x="5" y="2" width="250" height="14" fontSize="9.0" bold="true"
                 forecolor="#FFFFFF" vTextAlign="Middle">
            <text><![CDATA[Objective Title & Description]]></text>
        </element>
        <element kind="staticText" uuid="bb000032-0001-0001-0001-000000000032"
                 x="260" y="2" width="170" height="14" fontSize="9.0" bold="true"
                 forecolor="#FFFFFF" vTextAlign="Middle">
            <text><![CDATA[Success Criteria]]></text>
        </element>
        <element kind="staticText" uuid="bb000033-0001-0001-0001-000000000033"
                 x="435" y="2" width="60" height="14" fontSize="9.0" bold="true"
                 forecolor="#FFFFFF" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[Progress]]></text>
        </element>
        <element kind="staticText" uuid="bb000034-0001-0001-0001-000000000034"
                 x="500" y="2" width="50" height="14" fontSize="9.0" bold="true"
                 forecolor="#FFFFFF" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[Status]]></text>
        </element>
    </columnHeader>

    <!-- ===================== DETAIL (one band per objective row) ===================== -->
    <detail>
        <band height="65" splitType="Stretch">
            <!-- Alternating row background -->
            <element kind="rectangle" uuid="bb000040-0001-0001-0001-000000000040"
                     x="0" y="0" width="555" height="65" backcolor="#F9FAFB">
                <pen lineWidth="0"/>
                <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
            </element>

            <!-- Objective title -->
            <element kind="textField" uuid="bb000041-0001-0001-0001-000000000041"
                     x="5" y="5" width="250" height="15" fontSize="9.5" bold="true"
                     forecolor="#111827">
                <expression><![CDATA[$F{objectiveTitle}]]></expression>
            </element>

            <!-- Objective description -->
            <element kind="textField" uuid="bb000042-0001-0001-0001-000000000042"
                     x="5" y="22" width="250" height="38" fontSize="8.5"
                     forecolor="#4B5563" textAdjust="StretchHeight">
                <expression><![CDATA[$F{objectiveDescription}]]></expression>
            </element>

            <!-- Success Criteria -->
            <element kind="textField" uuid="bb000043-0001-0001-0001-000000000043"
                     x="260" y="5" width="170" height="55" fontSize="8.5"
                     forecolor="#4B5563" textAdjust="StretchHeight">
                <expression><![CDATA[$F{successCriteria} != null ? $F{successCriteria} : "\u2014"]]></expression>
            </element>

            <!-- Progress percent -->
            <element kind="textField" uuid="bb000044-0001-0001-0001-000000000044"
                     x="435" y="20" width="60" height="15" fontSize="10.0" bold="true"
                     hTextAlign="Center" forecolor="#1D4ED8">
                <expression><![CDATA[$F{progressPercent}]]></expression>
            </element>

            <!-- Status -->
            <element kind="textField" uuid="bb000045-0001-0001-0001-000000000045"
                     x="500" y="20" width="50" height="15" fontSize="9.0" bold="true"
                     hTextAlign="Center" forecolor="#374151">
                <expression><![CDATA[$F{status}]]></expression>
            </element>

            <!-- Row divider -->
            <element kind="line" uuid="bb000046-0001-0001-0001-000000000046"
                     x="0" y="63" width="555" height="1" forecolor="#E5E7EB">
                <pen lineWidth="0.5"/>
            </element>
        </band>
    </detail>

    <!-- ===================== SUMMARY (final overall comments) ===================== -->
    <summary height="125">
        <element kind="textField" uuid="summary-objectives-count"
                 x="0" y="5" width="555" height="15" fontSize="9.5" bold="true" forecolor="#1F2937">
            <expression><![CDATA["Total Objectives: " + $V{REPORT_COUNT}]]></expression>
        </element>
        <element kind="staticText" uuid="bb000060-0001-0001-0001-000000000060"
                 x="0" y="25" width="555" height="15" fontSize="10.0" bold="true" forecolor="#1F2937">
            <text><![CDATA[Overall Final Comments / Review Remarks]]></text>
        </element>
        <element kind="textField" uuid="bb000061-0001-0001-0001-000000000061"
                 x="0" y="45" width="555" height="60" fontSize="9.0" forecolor="#4B5563"
                 textAdjust="StretchHeight">
            <expression><![CDATA[$P{overallComment} != null && !$P{overallComment}.isEmpty() ? $P{overallComment} : "No overall comments registered."]]></expression>
        </element>
    </summary>

    <!-- ===================== PAGE FOOTER ===================== -->
    <pageFooter height="30">
        <element kind="line" uuid="bb000050-0001-0001-0001-000000000050"
                 x="0" y="5" width="555" height="1" forecolor="#E5E7EB"/>
        <element kind="textField" uuid="bb000051-0001-0001-0001-000000000051"
                 x="0" y="10" width="300" height="15" fontSize="8.0" forecolor="#9CA3AF">
            <expression><![CDATA["Generated on: " + new java.text.SimpleDateFormat("dd-MM-yyyy HH:mm").format(new java.util.Date())]]></expression>
        </element>
        <element kind="textField" uuid="bb000052-0001-0001-0001-000000000052"
                 x="455" y="10" width="100" height="15" fontSize="8.0"
                 forecolor="#9CA3AF" hTextAlign="Right">
            <expression><![CDATA["Page " + $V{PAGE_NUMBER}]]></expression>
        </element>
    </pageFooter>

</jasperReport>
