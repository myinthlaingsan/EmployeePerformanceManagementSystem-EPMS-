<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="employee_master_report" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<parameter name="logoStream" class="java.io.InputStream"/>
	<parameter name="reportTitle" class="java.lang.String"/>
	<field name="employeeCode" class="java.lang.String"/>
	<field name="staffName" class="java.lang.String"/>
	<field name="email" class="java.lang.String"/>
	<field name="departmentName" class="java.lang.String"/>
	<field name="teamName" class="java.lang.String"/>
	<field name="positionName" class="java.lang.String"/>
	<field name="levelName" class="java.lang.String"/>
	<field name="directManagerName" class="java.lang.String"/>
	<field name="status" class="java.lang.String"/>
	<field name="joinedDate" class="java.lang.String"/>

	<variable name="ROW_COUNT" class="java.lang.Integer" calculation="Count">
		<expression><![CDATA[$F{employeeCode}]]></expression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>

	<title height="70">
		<element kind="image" x="0" y="0" width="100" height="50">
			<expression><![CDATA[$P{logoStream}]]></expression>
		</element>
		<element kind="textField" x="100" y="0" width="600" height="50" fontSize="22.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<expression><![CDATA[$P{reportTitle} != null ? $P{reportTitle} : "Employee Master Report"]]></expression>
		</element>
	</title>
	<columnHeader height="35">
		<element kind="rectangle" x="0" y="0" width="802" height="35" backcolor="#34495E">
			<pen lineWidth="0.0"/>
		</element>
		<element kind="staticText" x="0" y="0" width="70" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Code]]></text>
			<box leftPadding="5"/>
		</element>
		<element kind="staticText" x="70" y="0" width="120" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Staff Name]]></text>
		</element>
		<element kind="staticText" x="190" y="0" width="90" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Department]]></text>
		</element>
		<element kind="staticText" x="280" y="0" width="90" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Team]]></text>
		</element>
		<element kind="staticText" x="370" y="0" width="100" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Position]]></text>
		</element>
		<element kind="staticText" x="470" y="0" width="70" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Level]]></text>
		</element>
		<element kind="staticText" x="540" y="0" width="110" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Manager]]></text>
		</element>
		<element kind="staticText" x="650" y="0" width="60" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Status]]></text>
		</element>
		<element kind="staticText" x="710" y="0" width="92" height="35" forecolor="#FFFFFF" fontSize="8.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Joined Date]]></text>
		</element>
	</columnHeader>
	<detail>
		<band height="30">
			<element kind="textField" x="0" y="0" width="70" height="30" fontSize="8.0" vTextAlign="Middle">
				<expression><![CDATA[$F{employeeCode}]]></expression>
				<box leftPadding="5">
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="70" y="0" width="120" height="30" fontSize="8.0" bold="true" vTextAlign="Middle">
				<expression><![CDATA[$F{staffName}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="190" y="0" width="90" height="30" fontSize="8.0" vTextAlign="Middle">
				<expression><![CDATA[$F{departmentName}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="280" y="0" width="90" height="30" fontSize="8.0" vTextAlign="Middle">
				<expression><![CDATA[$F{teamName}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="370" y="0" width="100" height="30" fontSize="8.0" vTextAlign="Middle">
				<expression><![CDATA[$F{positionName}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="470" y="0" width="70" height="30" fontSize="8.0" vTextAlign="Middle">
				<expression><![CDATA[$F{levelName}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="540" y="0" width="110" height="30" fontSize="8.0" vTextAlign="Middle">
				<expression><![CDATA[$F{directManagerName}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="650" y="0" width="60" height="30" fontSize="8.0" hTextAlign="Center" vTextAlign="Middle">
				<expression><![CDATA[$F{status}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
			<element kind="textField" x="710" y="0" width="92" height="30" fontSize="8.0" hTextAlign="Center" vTextAlign="Middle">
				<expression><![CDATA[$F{joinedDate}]]></expression>
				<box>
					<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
				</box>
			</element>
		</band>
	</detail>

	<pageFooter height="30">
		<element kind="textField" x="0" y="10" width="200" height="20" fontSize="8.0" pattern="dd-MM-yyyy HH:mm:ss" vTextAlign="Middle">
			<expression><![CDATA[new java.util.Date()]]></expression>
		</element>
		<element kind="textField" x="600" y="10" width="150" height="20" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle">
			<expression><![CDATA["Page " + $V{PAGE_NUMBER} + " of "]]></expression>
		</element>
		<element kind="textField" x="750" y="10" width="52" height="20" fontSize="8.0" evaluationTime="Report" hTextAlign="Left" vTextAlign="Middle">
			<expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression>
		</element>
	</pageFooter>

	<summary height="40">
		<element kind="line" x="0" y="5" width="802" height="1">
			<pen lineWidth="1.0" lineColor="#34495E"/>
		</element>
		<element kind="staticText" x="0" y="10" width="150" height="25" fontSize="10.0" bold="true" vTextAlign="Middle">
			<text><![CDATA[Total Employees:]]></text>
		</element>
		<element kind="textField" x="150" y="10" width="100" height="25" fontSize="10.0" bold="true" vTextAlign="Middle">
			<expression><![CDATA[$V{ROW_COUNT}]]></expression>
		</element>
	</summary>
</jasperReport>